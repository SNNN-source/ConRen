# Backend environment example for ConRen.
#
# Beginner note:
# Create a file named `.env` inside the `backend/` folder and paste your real
# MongoDB connection string there. The backend reads this value on startup.

MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
APP_SECRET=replace_with_a_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password
