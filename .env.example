# Root frontend environment example.
#
# Beginner note:
# This file came from the original starter template used for the frontend.
# The current ConRen project does not rely on Gemini features in the main user
# flow, so most beginners can ignore this file unless they plan to add AI.

# GEMINI_API_KEY: Required only if Gemini AI API calls are added later.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where the app is hosted.
# Useful for links, callbacks, and external integrations.
APP_URL="MY_APP_URL"
